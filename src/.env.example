# OCI Layer Builder Configuration
# Copy this file to .env and fill in your values

# Container Registry
# Options: ghcr.io, docker.io, gcr.io, etc.
REGISTRY=ghcr.io

# Repository name (without registry prefix)
# Example: username/resume or organization/project
REPOSITORY=username/resume

# Image tag
TAG=latest

# Output directory for OCI layout
OUTPUT_DIR=oci-layout

# Root directory to search for .tex files
# Default is parent directory (..)
ROOT_DIR=..
